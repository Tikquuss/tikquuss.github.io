---
import { resolveUrl } from '../lib/site';

interface Props {
  href: string;
  title: string;
  authors: string;
  venue: string;
  date: string;
  tags?: string[];
  image?: string;
}

const { href, title, authors, venue, date, tags = [], image } = Astro.props;
const year = new Date(date).getFullYear();
---

<a href={href} class="pub-card">
  <div class="pub-thumb">
    {image ? (
      <img src={resolveUrl(image)} alt="" loading="lazy" />
    ) : (
      <span class="pub-thumb-mark">ML</span>
    )}
  </div>
  <div class="pub-meta">
    <div class="pub-title">{title}</div>
    <div class="pub-authors">{authors}</div>
    <div class="pub-venue">{venue} · {year}</div>
    {tags.length > 0 && (
      <div class="tags">
        {tags.slice(0, 4).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
