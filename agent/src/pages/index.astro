---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsSection from '../components/NewsSection.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';
import { SITE, withBase } from '../lib/site';

const publications = await getCollection('publications');
const sortedPubs = publications
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const news = [
  { date: 'May 2026', text: 'Recognized as an <strong>ICML 2026 Gold Reviewer</strong> (top 25%) and awarded complimentary registration.' },
  { date: 'Apr 2026', text: 'New preprint: <a href="https://arxiv.org/abs/2604.01329">Model Merging via Data-Free Covariance Estimation</a>.' },
  { date: 'Feb 2026', text: `New paper: <a href="${withBase('/publications/grokking-finite-dimensional-algebra/')}">Grokking Finite-Dimensional Algebra</a> accepted at <strong>ICML 2026</strong>.` },
  { date: 'Jul 2025', text: `<a href="${withBase('/publications/grokking-beyond-l2/')}">Grokking Beyond the Euclidean Norm</a> accepted at <strong>ICML 2025</strong>.` },
];
---

<BaseLayout
  title="Home"
  description="Pascal Jr. Tikeng Notsawo - PhD student in Machine Learning Theory at Mila and Université de Montréal."
  wide={true}
>
  <section class="home-hero">
    <div class="hero-photo-wrap">
      <img class="hero-photo" src={withBase('/images/people/pascal.jpg')} alt="Pascal Jr. Tikeng Notsawo" />
    </div>

    <div class="hero-content">
      <p class="eyebrow">Optimization · Machine Learning · Machine Unlearning</p>
      <h1 class="hero-tagline">I learn stuff.</h1>

      <div class="hero-links">
        <a href={SITE.cvUrl} class="hero-link primary" target="_blank" rel="noopener">CV</a>
        <a href={withBase('/publications')} class="hero-link secondary">Publications</a>
        <a href={SITE.scholarUrl} class="hero-link secondary" target="_blank" rel="noopener">Google Scholar</a>
        <a href={SITE.githubUrl} class="hero-link secondary" target="_blank" rel="noopener">GitHub</a>
        <a href={SITE.linkedinUrl} class="hero-link secondary" target="_blank" rel="noopener">LinkedIn</a>
        <a href={withBase('/blog')} class="hero-link secondary">Blog</a>
      </div>

      <div class="research-interests">
        <h2>Research Interests</h2>
        <div class="interest-chips">
          <span class="interest-chip">Optimization</span>
          <span class="interest-chip">Generalization</span>
          <span class="interest-chip">Deep Learning Theory</span>
          <span class="interest-chip">Grokking</span>
          <span class="interest-chip">AI Alignment</span>
          <span class="interest-chip">LLM Unlearning</span>
        </div>
      </div>
    </div>
  </section>

  <NewsSection items={news} />

  <aside class="math-note" aria-label="Mathematical aside">
    If I were a mathematician like
    <a href="https://darsakthi.github.io/" target="_blank" rel="noopener">Dalton A. R. Sakthivadivel</a>,
    I would have written:
    <span class="math-quote">
      "Enter this website if and only if your personal model of mathematics is consistent with
      <a href="https://fardila.com/" target="_blank" rel="noopener">Ardila's axioms</a>."
    </span>
  </aside>

  <aside class="site-note" aria-label="Site note">
    <strong>Site note.</strong> This website is still being rebuilt. I am moving from an older
    Jekyll setup that became a bit painful to maintain, so some pages, links, and formatting are
    still being cleaned up as I migrate everything into this new version.
  </aside>

  <section>
    <div class="section-header">
      <div class="section-label">Selected Publications</div>
      <h2>Recent Work</h2>
      <div class="section-divider"></div>
    </div>

    <div class="stack">
      {sortedPubs.map((pub) => (
        <PublicationCard
          href={withBase(`/publications/${pub.slug}`)}
          title={pub.data.title}
          authors={pub.data.authors}
          venue={pub.data.venue}
          date={pub.data.date}
          tags={pub.data.tags}
          image={pub.data.image}
        />
      ))}
    </div>

    <p class="section-link">
      <a href={withBase('/publications')}>View all publications →</a>
    </p>
  </section>
</BaseLayout>
