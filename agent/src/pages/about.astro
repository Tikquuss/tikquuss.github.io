---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsSection from '../components/NewsSection.astro';
import { SITE, withBase } from '../lib/site';

const news = [
  { date: 'May 2026', text: 'Recognized as an <strong>ICML 2026 Gold Reviewer</strong> (top 25%) and awarded complimentary registration.' },
  { date: 'Apr 2026', text: 'New preprint: <a href="https://arxiv.org/abs/2604.01329">Model Merging via Data-Free Covariance Estimation</a>.' },
  { date: 'Feb 2026', text: `New paper: <a href="${withBase('/publications/grokking-finite-dimensional-algebra/')}">Grokking Finite-Dimensional Algebra</a> accepted at <strong>ICML 2026</strong>.` },
  { date: 'Jul 2025', text: `<a href="${withBase('/publications/grokking-beyond-l2/')}">Grokking Beyond the Euclidean Norm of Model Parameters</a> accepted at <strong>ICML 2025</strong>.` },
];
---

<BaseLayout title="About" description="About Pascal Jr. Tikeng Notsawo.">
  <div class="section-header">
    <div class="section-label">About</div>
    <h1>Pascal Jr. Tikeng Notsawo</h1>
    <div class="section-divider"></div>
  </div>

  <div class="about-grid">
    <aside class="profile-aside">
      <img class="profile-photo" src={withBase('/images/people/pascal.jpg')} alt="Pascal Jr. Tikeng Notsawo" />
      <div class="profile-links">
        <a href={SITE.cvUrl} class="btn btn-primary" target="_blank" rel="noopener">CV</a>
        <a href={SITE.scholarUrl} class="btn btn-secondary" target="_blank" rel="noopener">Scholar</a>
        <a href={SITE.githubUrl} class="btn btn-secondary" target="_blank" rel="noopener">GitHub</a>
        <a href={SITE.linkedinUrl} class="btn btn-secondary" target="_blank" rel="noopener">LinkedIn</a>
        <div class="profile-email">
          <span>Email</span>
          <code>{SITE.authorEmail}</code>
        </div>
      </div>
    </aside>

    <div class="prose">
      <p>
        I am a third-year PhD candidate at
        <a href="https://mila.quebec" target="_blank" rel="noopener">Mila</a> and
        <a href="https://www.umontreal.ca" target="_blank" rel="noopener">Université de Montréal</a>,
        working on machine learning theory and language models. My previous research focused on
        generalization, optimization dynamics, and representation learning in neural networks, including
        theoretical and empirical studies of grokking and implicit bias in deep learning.
      </p>

      <p>
        More recently, my research has shifted toward AI safety and alignment, with a focus on LLM
        unlearning. I am currently collaborating with Tommaso Tosato from
        <a href="https://tararesearch.org/" target="_blank" rel="noopener">Tara Research</a> on
        unlearning methods for studying and improving honesty in language models.
        I am interested in connecting empirical alignment work with theoretical
        understanding of learning dynamics and representation formation in neural networks.
      </p>

      <p>
        I earned a Master of Engineering in Computer Science from National Advanced 
        School of Engineering, Yaoundé. Before starting my PhD, I was a Visiting Student 
        Researcher at Université de Montréal and a Research Intern at Mila, where I worked 
        with Yoshua Bengio and Dianbo Liu. I also contributed to language technology for 
        African languages and conducted research on the detection and mitigation of 
        discriminatory language in online text.
      </p> 

      <NewsSection items={news} />
    </div>
  </div>
</BaseLayout>
